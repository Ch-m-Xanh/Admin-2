# Chuoi ket noi MongoDB. Local: mongodb://127.0.0.1:27017/cham-xanh
# Production (Render): dan connection string cua MongoDB Atlas M0 (512MB free) vao day.
MONGODB_URI=mongodb://127.0.0.1:27017/cham-xanh

# Khoa ky JWT - production hay doi thanh chuoi ngau nhien that dai.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret

# Cong chay server (Render tu cap PORT, local mac dinh 4000).
PORT=4000

# Danh sach origin trinh duyet duoc phep (cach nhau boi dau phay).
# App Mobile khong gui Origin header nen khong bi anh huong.
# De trong = cho phep tat ca (tien khi dev / deploy chung 1 domain).
ALLOWED_ORIGINS=
